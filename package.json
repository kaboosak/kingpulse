    "allowance": "HARDHAT_NETWORK=monad node scripts/allowance.js",
    "allowance:mainnet": "HARDHAT_NETWORK=monad node scripts/allowance.js",
    "burn": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/burn.js",
    "burn:mainnet": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/burn.js",
    "burn:mainnet:operator": "KINGPULSE_SIGNER=operator HARDHAT_NETWORK=monad node scripts/burn.js",
    "burn-from": "KINGPULSE_SIGNER=operator HARDHAT_NETWORK=monad node scripts/burn-from.js",
    "burn-from:mainnet": "KINGPULSE_SIGNER=operator HARDHAT_NETWORK=monad node scripts/burn-from.js",
    "pause": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/pause.js",
    "pause:mainnet": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/pause.js",
    "unpause": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/unpause.js",
    "unpause:mainnet": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/unpause.js",
    "transfer-ownership": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/transfer-ownership.js",
    "transfer-ownership:mainnet": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/transfer-ownership.js",
    "balance": "HARDHAT_NETWORK=monad node scripts/balance.js",
