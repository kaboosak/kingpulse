{
  "dependencies": {
    "@metamask/connect-evm": "^0.9.1",
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.28.6"
  },
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js",
    "deploy:monad": "hardhat run scripts/deploy.js --network monad",
    "deploy:monad:mainnet": "hardhat run scripts/deploy.js --network monadMainnet",
    "verify:monad": "hardhat verify --network monad",
    "verify:monad:mainnet": "hardhat verify --network monadMainnet",
    "frontend:monad": "node scripts/serve-frontend.js",
    "mint:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/mint.js",
    "mint:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/mint.js",
    "transfer:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/transfer.js",
    "transfer:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/transfer.js",
    "transfer:monad:spender": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monad node scripts/transfer.js",
    "approve:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/approve.js",
    "approve:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/approve.js",
    "approve:monad:spender": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monad node scripts/approve.js",
    "allowance:monad": "HARDHAT_NETWORK=monad node scripts/allowance.js",
    "allowance:monad:mainnet": "HARDHAT_NETWORK=monadMainnet node scripts/allowance.js",
    "burn:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/burn.js",
    "burn:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/burn.js",
    "burn:monad:spender": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monad node scripts/burn.js",
    "burn-from:monad": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monad node scripts/burn-from.js",
    "burn-from:monad:mainnet": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monadMainnet node scripts/burn-from.js",
    "pause:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/pause.js",
    "pause:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/pause.js",
    "unpause:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/unpause.js",
    "unpause:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/unpause.js",
    "transfer-ownership:monad": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/transfer-ownership.js",
    "transfer-ownership:monad:mainnet": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/transfer-ownership.js",
    "balance:monad": "HARDHAT_NETWORK=monad node scripts/balance.js",
    "balance:monad:mainnet": "HARDHAT_NETWORK=monadMainnet node scripts/balance.js",
    "native-balance:monad": "HARDHAT_NETWORK=monad node scripts/native-balance.js",
    "native-balance:monad:mainnet": "HARDHAT_NETWORK=monadMainnet node scripts/native-balance.js",
    "token-info:monad": "HARDHAT_NETWORK=monad node scripts/token-info.js",
    "token-info:monad:mainnet": "HARDHAT_NETWORK=monadMainnet node scripts/token-info.js",
    "whoami:monad:owner": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monad node scripts/whoami.js",
    "whoami:monad:spender": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monad node scripts/whoami.js",
    "whoami:monad:mainnet:owner": "KINGPULSE_SIGNER=owner HARDHAT_NETWORK=monadMainnet node scripts/whoami.js",
    "whoami:monad:mainnet:spender": "KINGPULSE_SIGNER=spender HARDHAT_NETWORK=monadMainnet node scripts/whoami.js"
  }
}
