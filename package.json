{
  "type": "module",
  "engines": {
    "node": ">=22.10.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.7",
    "@nomicfoundation/hardhat-mocha": "^3.0.15",
    "@nomicfoundation/hardhat-verify": "^3.0.13",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.3.0",
    "mocha": "^11.7.5"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "scripts": {
    "compile": "hardhat compile",
    "compile:legacy": "hardhat --build-profile legacy compile",
    "clean": "hardhat clean",
    "test": "hardhat test --network hardhat",
    "deploy:local": "hardhat run scripts/deploy.js",
    "deploy": "hardhat run scripts/deploy.js --network monad",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network monad",
    "verify": "hardhat verify --network monad",
    "verify:mainnet": "hardhat verify --network monad",
    "verify:legacy": "hardhat --build-profile legacy verify --network monad",
    "verify:mainnet:legacy": "hardhat --build-profile legacy verify --network monad",
    "deploy-vesting": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/deploy-vesting-wallet.js",
    "vesting-batch": "bash scripts/automate-vesting.sh",
    "vesting-status": "HARDHAT_NETWORK=monad node scripts/vesting-status.js",
    "release-vested": "HARDHAT_NETWORK=monad node scripts/release-vested.js",
    "frontend": "node scripts/serve-frontend.js",
    "frontend:monad": "node scripts/serve-frontend.js",
    "mint": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/mint.js",
    "mint:mainnet": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/mint.js",
    "transfer": "KINGPULSE_SIGNER=admin HARDHAT_NETWORK=monad node scripts/transfer.js",
